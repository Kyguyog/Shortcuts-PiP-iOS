<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Background Audio + AirPlay + Picture in Picture -->
    <key>com.apple.background-mode.audio</key>
    <true/>

    <!-- App Sandbox — must be false for sideloading without provisioning profile -->
    <key>com.apple.security.app-sandbox</key>
    <false/>
</dict>
</plist>
